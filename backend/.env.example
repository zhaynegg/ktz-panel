# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_AUTH_ENABLED=false

# --- Database (Supabase pooler or local Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kzt

# --- Auth (flip to true when Supabase Auth is wired) ---
AUTH_ENABLED=false

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Simulator ---
SIM_TICK_INTERVAL_S=1.0
SIM_LOCOMOTIVE_TYPE=electric
# SIM_SEED=42

# --- Processing ---
EMA_ALPHA=0.3
TELEMETRY_BUFFER_SIZE=1800
TELEMETRY_HISTORY_DB_PATH=./data/telemetry_history.sqlite3
TELEMETRY_HISTORY_RETENTION_HOURS=72
HEALTH_CONFIG_PATH=./config/health_index.json

# --- AI analysis ---
AI_ANALYSIS_ENABLED=true
AI_ANALYSIS_WINDOW_MINUTES=10
AI_ANALYSIS_CACHE_SECONDS=600
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Logging ---
LOG_LEVEL=INFO
